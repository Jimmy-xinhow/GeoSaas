# ============================================
# Geovault API — Environment Variables
# Copy to .env and fill in actual values
# ============================================

# Server
PORT=4000
NODE_ENV=development
API_PUBLIC_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3001

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geo_saas

# Redis (Upstash)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# JWT Authentication
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# AI APIs
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# IndexNow (for AI crawler notification)
INDEXNOW_API_KEY=geovault-indexnow-key

# Search API for auto-discovery (priority: SerpAPI → Google → Bing)
SERP_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
BING_SEARCH_API_KEY=

# llms.txt verification
LLMS_VERIFY_SECRET=geo-saas-2025

# 藍新金流 NewebPay
NEWEBPAY_MERCHANT_ID=
NEWEBPAY_HASH_KEY=
NEWEBPAY_HASH_IV=
NEWEBPAY_API_URL=https://ccore.newebpay.com/MPG/mpg_gateway
NEWEBPAY_RETURN_URL=http://localhost:3001/settings/billing/result
NEWEBPAY_NOTIFY_URL=http://localhost:4000/api/payments/notify
NEWEBPAY_MODE=test

# Social Publishing (optional)
MEDIUM_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=
WORDPRESS_SITE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# AWS S3 (optional, for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=
