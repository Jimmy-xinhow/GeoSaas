# ============================================
# Geovault API — Environment Variables
# Copy to .env and fill in actual values
# ============================================

# Server
PORT=4000
NODE_ENV=development
API_PUBLIC_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3001

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geo_saas

# Redis (Upstash)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# JWT Authentication
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth (Sign in with Google)
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: https://www.geovault.app  (and http://localhost:3001 for dev)
# Authorized redirect URIs: not required for the GSI ID-token flow
GOOGLE_CLIENT_ID=

# AI APIs
ANTHROPIC_API_KEY=
# Optional: override the Claude model used by the AI-citation monitor detector.
# Defaults to a current Sonnet; set this if that model ID is retired for your account.
MONITOR_CLAUDE_MODEL=
# Optional: override the Gemini model used by the monitor detector (same reason).
MONITOR_GEMINI_MODEL=
OPENAI_API_KEY=
# Optional model override for first-party official-site articles.
# Official-site article generation defaults to Claude Opus 4.8.
OFFICIAL_SITE_ARTICLE_CLAUDE_MODEL=claude-opus-4-8
# Optional OpenAI fallback model if Claude is unavailable.
# GPT-5.6 Sol is used with high reasoning for SEO/GEO article generation and repair.
OFFICIAL_SITE_ARTICLE_AI_MODEL=gpt-5.6-sol
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Geovault <noreply@geovault.app>

# IndexNow (for AI crawler notification)
INDEXNOW_API_KEY=geovault-indexnow-key

# Guest scan public rate limit
GUEST_DAILY_LIMIT=3

# Search Engine Push (proactive URL submission)
GOOGLE_INDEXING_API_KEY=
BING_WEBMASTER_API_KEY=

# Discovery industry enrichment (writes AI-synthesized Q&A into SiteQa with no
# quality/citation gate — polluted brand-profile/faq inputs). Keep disabled;
# set to 1 only if the enrichment output gets its own gate.
DISCOVERY_ENRICH_ENABLED=0

# Search API for auto-discovery (priority: SerpAPI → Google → Bing)
SERP_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
BING_SEARCH_API_KEY=

# llms.txt verification
LLMS_VERIFY_SECRET=geo-saas-2025

# Long-tail article QA/repair cron
CONTENT_QA_CRON_DISABLED=0
CONTENT_QA_BATCH_LIMIT=25
CONTENT_QA_REPAIR_MODEL=gpt-4o-mini

# Legacy self-rated GEO article factory. Keep frozen so old score-centric
# templates cannot be generated from cron, admin endpoints, or refill tasks.
# client_daily weekly customer delivery does not use this switch.
LEGACY_GEO_BULK_ENABLED=0
# Safe legacy replacement scheduler stays in preview mode until a small
# production batch has verified aliases, permanent redirects and canonical URLs.
LEGACY_REPLACEMENT_APPLY_ENABLED=0

# Industry AI weekly benchmark cost controls
# Keep the core benchmark feature enabled, but bound the automatic weekly batch.
INDUSTRY_AI_SCHEDULED_ENABLED=1
INDUSTRY_AI_SCHEDULED_INDUSTRIES=auto_care,traditional_medicine
INDUSTRY_AI_SCHEDULED_MAX_SITES_PER_INDUSTRY=20
INDUSTRY_AI_SCHEDULED_MAX_QUERIES_PER_INDUSTRY=4
INDUSTRY_AI_SCHEDULED_PLATFORMS=CHATGPT,CLAUDE,PERPLEXITY,GEMINI,COPILOT
INDUSTRY_AI_SCHEDULED_MAX_CALLS_PER_INDUSTRY=500
INDUSTRY_AI_SCHEDULED_MAX_COPILOT_CALLS_PER_INDUSTRY=80
INDUSTRY_AI_ENABLE_COPILOT=1

# Support chat, AI triage, and staff notifications
SUPPORT_AI_ENABLED=1
SUPPORT_AI_MODEL=gpt-4o-mini
# Optional model override for knowledge file import; uses OPENAI_API_KEY.
KNOWLEDGE_IMPORT_AI_MODEL=gpt-4o-mini

# Citation-Readiness Gate + brand_profile rollout (uses ANTHROPIC_API_KEY).
# Cost lever: defaults to claude-opus-4-8; set the cheaper pair below for the
# 30-day directory rollout. Judge should stay >= gen quality.
BRAND_PROFILE_MODEL=claude-haiku-4-5
CRG_JUDGE_MODEL=claude-sonnet-4-6
# Brands generated per day by the brand-profile-rollout cron (06:00 UTC).
# ~617 brands-with-facts ÷ 30 days ≈ 21/day. Each brand attempted once.
BRAND_PROFILE_DAILY=21
SUPPORT_DEFAULT_KNOWLEDGE_ENABLED=1
SUPPORT_TELEGRAM_BOT_TOKEN=
SUPPORT_TELEGRAM_CHAT_ID=
SUPPORT_TELEGRAM_WEBHOOK_SECRET=
SUPPORT_LARK_WEBHOOK_URL=
SUPPORT_LARK_WEBHOOK_SECRET=

# Crawler analytics
# Keep disabled in production analytics. Set to 1 only for demo/dev seeded activity.
ENABLE_CRAWLER_SIMULATION=0

# 藍新金流 NewebPay
NEWEBPAY_MERCHANT_ID=
NEWEBPAY_HASH_KEY=
NEWEBPAY_HASH_IV=
NEWEBPAY_API_URL=https://ccore.newebpay.com/MPG/mpg_gateway
NEWEBPAY_PERIOD_API_URL=https://ccore.newebpay.com/MPG/period
NEWEBPAY_PERIOD_ALTER_STATUS_API_URL=https://ccore.newebpay.com/MPG/period/AlterStatus
NEWEBPAY_RETURN_URL=http://localhost:4000/api/billing/return
NEWEBPAY_NOTIFY_URL=http://localhost:4000/api/billing/notify
NEWEBPAY_PERIOD_RETURN_URL=http://localhost:4000/api/billing/period/return
NEWEBPAY_PERIOD_NOTIFY_URL=http://localhost:4000/api/billing/period/notify
NEWEBPAY_MODE=test

# Social Publishing (optional)
MEDIUM_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=
WORDPRESS_SITE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# AWS S3 (optional, for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=
# Optional — override the public base URL (e.g. CloudFront / R2 custom domain).
# Defaults to https://{bucket}.s3.{region}.amazonaws.com
AWS_S3_PUBLIC_BASE_URL=
# Optional — set only for S3-compatible providers (Cloudflare R2, Backblaze B2,
# Wasabi, DigitalOcean Spaces, MinIO). Leave blank for AWS S3.
# R2 example:  https://<account-id>.r2.cloudflarestorage.com
# B2 example:  https://s3.us-west-004.backblazeb2.com
AWS_S3_ENDPOINT=
# Set to 'true' for R2 / B2 / MinIO. Leave blank for AWS S3.
AWS_S3_FORCE_PATH_STYLE=
