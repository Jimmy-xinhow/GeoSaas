# ===========================================================
# Geovault API — Production Environment Variables
# ===========================================================

# App
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://geovault.app
API_PUBLIC_URL=https://api.geovault.app

# Guest scan public rate limit
GUEST_DAILY_LIMIT=3

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Redis (Upstash)
REDIS_HOST=your-redis.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_TLS=true

# llms.txt verification
LLMS_VERIFY_SECRET=change-this-secret

# Long-tail article QA/repair cron
CONTENT_QA_CRON_DISABLED=0
CONTENT_QA_BATCH_LIMIT=25
CONTENT_QA_REPAIR_MODEL=gpt-4o-mini

# Support chat, AI triage, and staff notifications
SUPPORT_AI_ENABLED=1
SUPPORT_AI_MODEL=gpt-4o-mini
SUPPORT_TELEGRAM_BOT_TOKEN=
SUPPORT_TELEGRAM_CHAT_ID=
SUPPORT_TELEGRAM_WEBHOOK_SECRET=
SUPPORT_LARK_WEBHOOK_URL=
SUPPORT_LARK_WEBHOOK_SECRET=

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# AI Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
PERPLEXITY_API_KEY=pplx-...
GEMINI_API_KEY=...

# Microsoft Copilot (Azure OpenAI Service)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# 藍新金流 NewebPay
NEWEBPAY_MERCHANT_ID=
NEWEBPAY_HASH_KEY=
NEWEBPAY_HASH_IV=
NEWEBPAY_API_URL=https://core.newebpay.com/MPG/mpg_gateway
NEWEBPAY_PERIOD_API_URL=https://core.newebpay.com/MPG/period
NEWEBPAY_PERIOD_ALTER_STATUS_API_URL=https://core.newebpay.com/MPG/period/AlterStatus
NEWEBPAY_RETURN_URL=https://api.geovault.app/api/billing/return
NEWEBPAY_NOTIFY_URL=https://api.geovault.app/api/billing/notify
NEWEBPAY_PERIOD_RETURN_URL=https://api.geovault.app/api/billing/period/return
NEWEBPAY_PERIOD_NOTIFY_URL=https://api.geovault.app/api/billing/period/notify
NEWEBPAY_MODE=production

# Crawler analytics
# Keep disabled in production analytics. Set to 1 only for demo/dev seeded activity.
ENABLE_CRAWLER_SIMULATION=0

# Publishing Platforms (optional)
MEDIUM_TOKEN=
LINKEDIN_ACCESS_TOKEN=
WORDPRESS_API_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
