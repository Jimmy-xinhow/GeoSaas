# ===========================================================
# GEO-SaaS API — Production Environment Variables
# Copy to .env.production and fill in actual values
# ===========================================================

# App
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://your-domain.vercel.app

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host.neon.tech/geo_saas?sslmode=require

# Redis (Upstash)
REDIS_HOST=your-redis.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_TLS=true

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d

# AI Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
PERPLEXITY_API_KEY=pplx-...
GEMINI_API_KEY=...

# 藍新金流 NewebPay
NEWEBPAY_MERCHANT_ID=your-merchant-id
NEWEBPAY_HASH_KEY=your-32-byte-hash-key
NEWEBPAY_HASH_IV=your-16-byte-iv
NEWEBPAY_API_URL=https://core.newebpay.com/MPG/mpg_gateway
API_PUBLIC_URL=https://your-api-domain.com

# Publishing Platforms
MEDIUM_TOKEN=
LINKEDIN_ACCESS_TOKEN=
WORDPRESS_API_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
