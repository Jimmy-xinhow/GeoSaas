generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Enums ====================

enum UserRole {
  USER
  STAFF
  ADMIN
  SUPER_ADMIN
}

enum Plan {
  FREE
  STARTER
  PRO
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ContentType {
  FAQ
  ARTICLE
  KNOWLEDGE_BASE
  NEWS_RELEASE
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum PublishStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ==================== Models ====================

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  passwordHash     String?
  avatarUrl        String?
  googleId         String?   @unique
  emailVerified    Boolean   @default(false)
  role             UserRole  @default(USER)
  plan             Plan      @default(FREE)
  managedBy        String?   // SUPER_ADMIN userId who manages this client
  credits          Int       @default(0)
  freeGenUsed      Int       @default(0)    // monthly free generation counter
  freeGenResetAt   DateTime? // when to reset freeGenUsed (start of next month)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sites              Site[]
  contents           Content[]
  notifications      Notification[]
  orders             Order[]
  successCases       GeoSuccessCase[]
  creditTransactions CreditTransaction[]

  @@index([managedBy])
  @@map("users")
}

model CreditTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // topup | deduct | expire | refund
  amount      Int      // positive for topup, negative for deduct
  balance     Int      // balance after transaction
  description String   // "充值 50 點" / "手動生成知識庫 Q&A (-2點)"
  orderId     String?  // linked to Order if topup via payment
  expiresAt   DateTime? // for topup: purchase date + 12 months
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@map("credit_transactions")
}

model Site {
  id        String   @id @default(cuid())
  url       String
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // llms.txt hosting
  llmsTxt          String?   @db.Text
  llmsTxtUpdatedAt DateTime?

  // Directory & Leaderboard
  isPublic    Boolean  @default(false)
  industry    String?
  tier        String?
  bestScore   Int      @default(0)
  bestScoreAt DateTime?

  // Client tagging
  isClient     Boolean  @default(false)

  // Verified status
  isVerified   Boolean  @default(false)
  verifiedAt   DateTime?

  // Crawler tracking
  crawlerToken String? @unique

  scans               Scan[]
  monitors            Monitor[]
  competitors         Competitor[]
  contents            Content[]
  qas                 SiteQa[]
  crawlerVisits       CrawlerVisit[]
  crawlerRobotsChecks CrawlerRobotsCheck[]
  blogArticles        BlogArticle[]
  badges              SiteBadge[]
  successCases        GeoSuccessCase[]
  seedSource          SeedSource?
  clientQuerySets     ClientQuerySet[]
  monitorReports      MonitorReport[]
  industryAiResults   IndustryAiResult[]
  industryAiSnapshots IndustryAiSnapshot[]
  qualityLogs         ArticleQualityLog[]

  @@map("sites")
}


model Scan {
  id          String     @id @default(cuid())
  siteId      String
  site        Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  totalScore  Int        @default(0)
  status      ScanStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  completedAt DateTime?

  results ScanResult[]

  @@map("scans")
}

model ScanResult {
  id            String  @id @default(cuid())
  scanId        String
  scan          Scan    @relation(fields: [scanId], references: [id], onDelete: Cascade)
  indicator     String
  score         Int
  status        String  // pass | warning | fail
  details       Json
  suggestion    String?
  autoFixable   Boolean @default(false)
  generatedCode String? @db.Text

  @@map("scan_results")
}

model Content {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteId      String?
  site        Site?         @relation(fields: [siteId], references: [id])
  title       String
  body        String        @db.Text
  type        ContentType
  language    String        @default("zh-TW")
  seoScore    Int?
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  publications Publication[]

  @@map("contents")
}

model Publication {
  id          String        @id @default(cuid())
  contentId   String
  content     Content       @relation(fields: [contentId], references: [id], onDelete: Cascade)
  platform    String
  externalUrl String?
  status      PublishStatus @default(PENDING)
  publishedAt DateTime?
  metrics     Json?

  @@map("publications")
}

model Monitor {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  platform  String
  query     String
  mentioned Boolean  @default(false)
  position  Int?
  response  String?  @db.Text
  checkedAt DateTime @default(now())

  @@map("monitors")
}

model Competitor {
  id            String @id @default(cuid())
  siteId        String
  site          Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  competitorUrl String
  name          String
  latestScore   Int?

  @@map("competitors")
}

model Order {
  id              String      @id @default(cuid())
  merchantOrderNo String      @unique
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            String
  amount          Int
  status          OrderStatus @default(PENDING)
  tradeNo         String?
  paymentType     String?
  paidAt          DateTime?
  rawResponse     Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("orders")
}

model SiteQa {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  question  String
  answer    String   @db.Text
  category  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_qas")
}

model CrawlerVisit {
  id         String   @id @default(cuid())
  siteId     String
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  botName    String
  botOrg     String
  url        String
  statusCode Int?
  userAgent  String?  @db.Text
  isSeeded   Boolean  @default(false)
  visitedAt  DateTime @default(now())

  @@index([siteId, visitedAt])
  @@index([siteId, botName])
  @@index([isSeeded])
  @@map("crawler_visits")
}

model CrawlerRobotsCheck {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  robotsTxt   String?  @db.Text
  allowedBots Json?
  sitemapUrls Json?
  checkedAt   DateTime @default(now())

  @@map("crawler_robots_checks")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model BlogArticle {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  content     String   @db.Text
  category    String   @default("analysis")
  locale      String   @default("zh-TW")
  siteId      String?
  site        Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  published   Boolean  @default(true)
  readTime    String   @default("5 分鐘")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Template system
  templateType        String    @default("geo_overview")
  industrySlug        String?
  targetKeywords      String[]
  readingTimeMinutes  Int       @default(5)
  lastRegeneratedAt   DateTime?

  // Legacy slug history — when we rewrite a slug (e.g. CJK → ASCII for AI
  // crawler-friendliness), the old slug goes here so /blog/[oldSlug] keeps
  // working via 301 redirect to the canonical slug.
  aliasSlugs          String[]  @default([])

  // Success case relation
  successCase         GeoSuccessCase?

  // Quality runner — every attempt that ultimately landed as this article
  // is linked back here for traceability.
  qualityLogs         ArticleQualityLog[]

  @@index([category])
  @@index([siteId])
  @@index([published, createdAt])
  @@index([templateType, createdAt])
  @@index([industrySlug, createdAt])
  @@map("blog_articles")
}

// One row per generation attempt across all 8+ content paths
// (client_daily/*, brand_showcase, brand_spread/*, industry_top10,
// buyer_guide, industry_insights, …). pass/fail both recorded so we can
// build a quality-trend dashboard and tune prompts over time.
model ArticleQualityLog {
  id            String   @id @default(cuid())

  templateType  String   // e.g. "client_daily/tue_qa_deepdive", "brand_spread/medium"
  promptVersion String   // bump when prompt is materially changed (e.g. "v3")
  stage         String   // "outline" | "full" | "patch"
  attempt       Int      // 1-based within (templateType, siteId, day)

  passed        Boolean
  totalScore    Int      // 0-100
  ruleScores    Json     // { brandSaturation: 18, niche: 15, ... }
  failedRules   String[] // ["brand_saturation:7", "too_short:600"]

  model         String   // "gpt-4o" | "gpt-4o-mini" | …
  charCount     Int
  tokensIn      Int?
  tokensOut     Int?
  durationMs    Int

  siteId        String?
  site          Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)

  // If this attempt's content ultimately landed as a published article,
  // the BlogArticle id is filled in. Failed attempts leave this null.
  articleId     String?
  article       BlogArticle? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())

  @@index([templateType, createdAt])
  @@index([siteId, createdAt])
  @@index([passed, templateType])
  @@index([promptVersion, templateType])
  @@map("article_quality_logs")
}

model SiteBadge {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  badge     String   // e.g. "first_scan", "score_50", "score_80", "score_100", "crawler_visited", "top_10", "improver"
  label     String   // Display label
  awardedAt DateTime @default(now())

  @@unique([siteId, badge])
  @@index([siteId])
  @@map("site_badges")
}

model GeoSuccessCase {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteId          String?
  site            Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)

  title           String
  aiPlatform      String
  queryUsed       String
  aiResponse      String    @db.Text
  screenshotUrl   String?
  beforeGeoScore  Int?
  afterGeoScore   Int?
  improvementDays Int?

  industry        String?
  tags            String[]

  generatedArticleId String?  @unique
  generatedArticle   BlogArticle? @relation(fields: [generatedArticleId], references: [id], onDelete: SetNull)

  status          String    @default("pending")
  rejectionReason String?
  featuredAt      DateTime?

  viewCount       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([aiPlatform, status])
  @@index([industry, status])
  @@index([featuredAt])
  @@map("geo_success_cases")
}

model NewsArticle {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  titleEn       String?
  titleJa       String?
  summary       String   @db.Text
  summaryEn     String?  @db.Text
  summaryJa     String?  @db.Text
  sourceUrl     String
  sourceName    String
  category      String   @default("ai-seo")
  imageUrl      String?
  published     Boolean  @default(true)
  publishedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([category, publishedAt])
  @@index([published, publishedAt])
  @@map("news_articles")
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}

model ScheduledTask {
  id            String    @id @default(cuid())
  taskKey       String    @unique
  name          String
  description   String?
  cronExpr      String    // e.g. "0 2 * * *"
  enabled       Boolean   @default(true)
  lastRunAt     DateTime?
  lastResult    String?
  nextRunAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("scheduled_tasks")
}

model SeedSource {
  id          String   @id @default(cuid())
  url         String   @unique
  brandName   String
  industry    String
  country     String   @default("TW")
  source      String   @default("manual")
  status      String   @default("pending")
  failReason  String?
  siteId      String?  @unique
  site        Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([industry, status])
  @@index([country, status])
  @@index([status])
  @@map("seed_sources")
}

model ClientQuerySet {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name        String   // e.g. "立如整復 驗收問題集"
  queries     Json     // array of { category, question }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reports     MonitorReport[]

  @@index([siteId])
  @@map("client_query_sets")
}

model MonitorReport {
  id            String   @id @default(cuid())
  querySetId    String
  querySet      ClientQuerySet @relation(fields: [querySetId], references: [id], onDelete: Cascade)
  siteId        String
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  period        String   // e.g. "2026-03"
  results       Json     // array of { question, platform, mentioned, response }
  summary       Json?    // { totalQueries, mentionedCount, mentionRate, byPlatform }
  status        String   @default("pending") // pending | running | completed
  completedAt   DateTime?
  createdAt     DateTime @default(now())

  @@index([siteId, period])
  @@index([querySetId])
  @@map("monitor_reports")
}

model GuestScan {
  id          String     @id @default(cuid())
  url         String
  ipHash      String
  totalScore  Int        @default(0)
  status      ScanStatus @default(PENDING)
  results     Json?
  createdAt   DateTime   @default(now())
  completedAt DateTime?

  @@index([ipHash, createdAt])
  @@index([url, createdAt])
  @@map("guest_scans")
}

// ==================== Industry AI Recommendation ====================

model IndustryQuery {
  id        String   @id @default(cuid())
  industry  String
  question  String
  category  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  results IndustryAiResult[]

  @@index([industry, isActive])
  @@map("industry_queries")
}

model IndustryAiResult {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  queryId   String
  query     IndustryQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  platform  String
  mentioned Boolean  @default(false)
  position  Int?
  response  String   @db.Text
  sentiment String?
  weekOf    DateTime
  checkedAt DateTime @default(now())

  @@unique([siteId, queryId, platform, weekOf])
  @@index([siteId, weekOf])
  @@index([queryId, platform, weekOf])
  @@index([siteId, platform, weekOf])
  @@map("industry_ai_results")
}

model IndustryAiSnapshot {
  id             String   @id @default(cuid())
  siteId         String
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  industry       String
  weekOf         DateTime
  totalChecks    Int      @default(0)
  mentionedCount Int      @default(0)
  mentionRate    Int      @default(0)
  byPlatform     Json
  avgSentiment   Float?
  createdAt      DateTime @default(now())

  @@unique([siteId, industry, weekOf])
  @@index([industry, weekOf])
  @@index([siteId, weekOf])
  @@map("industry_ai_snapshots")
}

model IndustryAiComparison {
  id        String   @id @default(cuid())
  siteAId   String
  siteBId   String
  industry  String
  platform  String
  question  String
  response  String   @db.Text
  weekOf    DateTime
  checkedAt DateTime @default(now())

  @@unique([siteAId, siteBId, platform, weekOf])
  @@index([industry, weekOf])
  @@map("industry_ai_comparisons")
}
